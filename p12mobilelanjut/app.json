{
  "expo": {
    "name": "p12mobilelanjut",
    "slug": "p12mobilelanjut",
    "scheme": "p12mobilelanjut",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.radin.p12mobilelanjut",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikasi membutuhkan kamera untuk membuat story.",
        "NSPhotoLibraryUsageDescription": "Aplikasi membutuhkan galeri untuk memilih dan menyimpan media.",
        "NSPhotoLibraryAddUsageDescription": "Aplikasi membutuhkan akses untuk menyimpan post ke galeri.",
        "NSLocationWhenInUseUsageDescription": "Aplikasi membutuhkan lokasi untuk menampilkan user terdekat."
      }
    },
    "android": {
      "package": "com.radin.p12mobilelanjut",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_MEDIA_IMAGES",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikasi membutuhkan kamera untuk membuat story."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Aplikasi membutuhkan galeri untuk memilih dan menyimpan media.",
          "savePhotosPermission": "Aplikasi membutuhkan akses untuk menyimpan post ke galeri.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-notifications"
    ]
  }
}
